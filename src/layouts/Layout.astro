---
import { brand } from '../config/brand';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, brand.domain).href;
const path = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
  { href: '/', label: 'Homepage', icon: 'home' },
  { href: '/about', label: 'About Us', icon: 'users' },
  { href: '/services/deck-refloor', label: 'Deck Refloor', icon: 'refresh' },
  { href: '/services/deck-facelift', label: 'Deck Facelift', icon: 'layers' },
  { href: '/services/custom-decks', label: 'Custom Decks', icon: 'hammer' },
  { href: '/pricing', label: 'Pricing', icon: 'dollar' },
  { href: '/montgomery-county-deck-permits', label: 'Permit Guide', icon: 'filecheck' },
  { href: '/portfolio', label: 'Portfolio', icon: 'image' },
  { href: '/contact', label: 'Contact Us', icon: 'mail' },
];

const icons: Record<string, string> = {
  home: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  refresh: '<path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/>',
  layers: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  hammer: '<path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"/>',
  dollar: '<line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
  filecheck: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m9 15 2 2 4-4"/>',
  image: '<rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>',
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: brand.name,
  legalName: brand.legalName,
  url: brand.domain,
  email: brand.email,
  description: brand.tagline,
  areaServed: [
    'Potomac MD', 'North Potomac MD', 'Gaithersburg MD', 'Bethesda MD',
    'Olney MD', 'Boyds MD', 'Clarksburg MD', 'Montgomery County MD',
  ].map((name) => ({ '@type': 'Place', name })),
  address: { '@type': 'PostalAddress', addressRegion: 'MD', addressCountry: 'US' },
  ...(brand.phone ? { telephone: brand.phone } : {}),
  ...(brand.mhic
    ? {
        hasCredential: {
          '@type': 'EducationalOccupationalCredential',
          credentialCategory: 'license',
          name: `Maryland Home Improvement Commission License #${brand.mhic}`,
        },
      }
    : {}),
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {!brand.launched && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    {!brand.launched && (
      <div class="preview-banner">
        PREVIEW BUILD — NOT PUBLISHED. Do not deploy publicly until the MHIC license number is issued and entered in brand.ts (COMAR 09.08.01.09).
      </div>
    )}

    <div class="shell">
      <aside class="sidebar" id="sidebar">
        <div class="logo-block">
          <a href="/">
            <h1>Belvedere Decks</h1>
            <p>Premium Composite Decking</p>
          </a>
        </div>
        <nav>
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`nav-link ${path === item.href ? 'active' : ''}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round" set:html={icons[item.icon]} />
              <span>{item.label}</span>
            </a>
          ))}
        </nav>
        <div class="side-footer">
          <p>© {new Date().getFullYear()} {brand.legalName}</p>
          <p>
            {brand.mhic
              ? `MHIC #${brand.mhic} · Licensed & Insured`
              : 'MHIC license pending — not yet offering home improvement services'}
          </p>
        </div>
      </aside>
      <div class="scrim" id="scrim"></div>

      <header class="mobile">
        <button id="menu-btn" aria-label="Open menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
          <span>Menu</span>
        </button>
        <span class="brand">Belvedere Decks</span>
        <a href="/contact" class="btn primary" style="padding: 8px 14px; font-size: 0.8rem;">Exact Price</a>
      </header>

      <main class="content">
        <div class="fixed-cta">
          <a href="/contact" class="btn primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Get your exact price
          </a>
        </div>

        <slot />

        <footer class="page-footer">
          <div class="container">
            <p>
              {brand.legalName} · Montgomery County, MD ·
              {brand.mhic
                ? `MHIC #${brand.mhic} · Licensed & Insured · `
                : 'MHIC license pending — not yet offering home improvement services · '}
              <a href="/montgomery-county-deck-permits">Permit Guide</a> ·
              <a href="/pricing">Pricing</a> ·
              <a href="/contact">Contact</a>
            </p>
          </div>
        </footer>
      </main>
    </div>

    <script>
      const btn = document.getElementById('menu-btn');
      const scrim = document.getElementById('scrim');
      btn?.addEventListener('click', () => document.body.classList.add('nav-open'));
      scrim?.addEventListener('click', () => document.body.classList.remove('nav-open'));
      document.querySelectorAll('.sidebar .nav-link').forEach((a) =>
        a.addEventListener('click', () => document.body.classList.remove('nav-open'))
      );
    </script>
  </body>
</html>
